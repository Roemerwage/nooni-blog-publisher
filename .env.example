# Klaviyo API Configuration
# Private key (sk_...) — server-side only, never expose in frontend
VITE_KLAVIYO_API_KEY=your_private_key_here
# Public key (pk_...) — safe to expose, used by Klaviyo.js in index.html
VITE_KLAVIYO_PUBLIC_KEY=your_public_key_here
# Email used as the Klaviyo profile for internal event tracking (blog publish, etc.)
VITE_KLAVIYO_ADMIN_EMAIL=team@getnooni.com
VITE_API_BASE_URL=http://localhost:3001

# Server Configuration
SERVER_PORT=3001
NODE_ENV=development
